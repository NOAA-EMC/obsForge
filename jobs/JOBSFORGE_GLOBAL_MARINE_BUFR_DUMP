#! /usr/bin/env bash

source "${HOMEobsforge}/ush/preamble.sh"
source "${HOMEobsforge}/ush/jjob_header.sh"

##############################################
# Set variables used in the script
##############################################
obsforge_ver=${obsforge_ver:-v1.0}
if ! ROTDIR=$(compath.py "${envir}/${NET}/${obsforge_ver}" 2>/dev/null); then
    echo "WARNING: compath.py failed; falling back to COMROOT=${COMROOT}"
    ROTDIR="${COMROOT}"
fi
export ROTDIR
export COMIN_OBSPROC="${ROTDIR}/${RUN}.${PDY}/${cyc}/ocean/insitu"

##############################################
# Begin JOB SPECIFIC work
##############################################

###############################################################
# Run relevant script

EXSCRIPT=${DUMPMARINEBUFRPY:-${HOMEobsforge}/scripts/exobsforge_global_marine_bufr_dump.py}
${EXSCRIPT}
status=$?
if [[ ${status} -ne 0 ]]; then
    exit "${status}"
fi


##############################################
# End JOB SPECIFIC work
##############################################

##############################################
# Final processing
##############################################
if [[ -e "${pgmout}" ]] ; then
  cat "${pgmout}"
fi

##########################################
# Remove the Temporary working directory
##########################################
cd "${DATAROOT}" || exit
if [[ "${KEEPDATA}" == "NO" ]]; then
    rm -rf "${DATA}"
fi

exit 0
